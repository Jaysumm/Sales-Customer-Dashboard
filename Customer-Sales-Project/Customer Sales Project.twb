            <run fontname='Tableau Bold' fontsize='22'><![CDATA[<[federated.153vz1j0spvqwe19ebmn21k7imea].[sum:Calculation_1747416790069295:qk]>]]></run>
            <run><![CDATA[
<[federated.153vz1j0spvqwe19ebmn21k7imea].[sum:Calculation_1747416790143024:qk]> ]]></run>
            <run fontcolor='#898989'>VS PY</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sales Data Source' name='federated.153vz1j0spvqwe19ebmn21k7imea' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Year' datatype='real' default-format='n0;(0)' name='[Parameter 1747415752912904]' param-domain-type='list' role='measure' type='quantitative' value='2023.0'>
              <calculation class='tableau' formula='2023.0' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.153vz1j0spvqwe19ebmn21k7imea'>
            <column caption='CY Customers' datatype='string' name='[Calculation_1747416670543914]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1747415752912904] THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='PY Customer' datatype='string' name='[Calculation_1747416672579627]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1747415752912904]-1 THEN [Customer ID]&#13;&#10;END' />
            </column>
            <column caption='% Diff Customers' datatype='real' name='[Calculation_1747416778936365]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(COUNTD([Calculation_1747416670543914]) - COUNTD([Calculation_1747416672579627])) / COUNTD([Calculation_1747416672579627])' />
            </column>
            <column caption='{COUNTD([CY Customers])}' datatype='integer' name='[Calculation_1747416790069295]' role='measure' type='quantitative' user:unnamed='Sheet 9'>
              <calculation class='tableau' formula='{COUNTD([Calculation_1747416670543914])}' />
            </column>
            <column caption='{[% Diff Customers]}' datatype='real' name='[Calculation_1747416790143024]' role='measure' type='quantitative' user:unnamed='Sheet 9'>
              <calculation class='tableau' formula='{[Calculation_1747416778936365]}' />
            </column>
            <column caption='Max/Min Customer' datatype='integer' name='[Calculation_1747416790499378]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF COUNTD([Calculation_1747416670543914]) = WINDOW_MAX(COUNTD([Calculation_1747416670543914]))&#13;&#10;THEN COUNTD([Calculation_1747416670543914])&#13;&#10;ELSEIF COUNTD([Calculation_1747416670543914]) = WINDOW_MIN(COUNTD([Calculation_1747416670543914]))&#13;&#10;THEN COUNTD([Calculation_1747416670543914])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
