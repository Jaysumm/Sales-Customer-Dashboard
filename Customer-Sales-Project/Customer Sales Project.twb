              <calculation class='tableau' formula='INT(REPLACE([Sales], &quot;,&quot;, &quot;&quot;))' />
            </column>
            <column caption='CY Sales' datatype='integer' name='[Calculation_1747415750864900]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1747415752912904] THEN [Calculation_1747415746498563]&#13;&#10;END' />
