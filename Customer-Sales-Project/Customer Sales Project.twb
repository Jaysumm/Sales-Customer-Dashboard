            </column>
            <column caption='% Diff Sales' datatype='real' default-format='p0.0%' name='[Calculation_1747415754874891]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_1747415750864900])-SUM([Calculation_1747415751581701]))/SUM([Calculation_1747415751581701])' />
            </column>
            <column caption='Max/Min Sales' datatype='integer' name='[Calculation_1747415759724556]' role='measure' type='quantitative'>
